flowchart LR
    subgraph Renderer["Renderer Process"]
        Mic["Microphone<br/>getUserMedia()"]
        AW["AudioWorklet<br/>pcm-capture-processor"]
        NG["Noise Gate<br/>RMS &lt; 0.015 dropped"]
        B64["Base64 Encode<br/>Int16 PCM 16kHz"]
        SC["Screen Capture<br/>JPEG frames"]
        Proxy["GeminiWsProxy<br/>ws-proxy.ts<br/>WebSocket-compatible IPC wrapper"]
        APE["AudioPlaybackEngine<br/>24kHz Web Audio<br/>backpressure 75%/90%"]
        SM["SessionManager<br/>rolling buffer<br/>reconnect at 5.5min"]
        TE["Tool Executor<br/>tool-executor.ts"]
        EM["Episodic Memory<br/>&gt;= 4 turns, &gt;= 60s"]
    end

    subgraph IPC["IPC Bridge (preload.ts)"]
        IPCout["window.eve.geminiLive.send()"]
        IPCin["window.eve.geminiLive.onMessage()"]
        IPCconn["window.eve.geminiLive.connect()<br/>API key injected here"]
    end

    subgraph Main["Main Process"]
        WSHandler["Gemini WebSocket Handler<br/>API key from settings<br/>never sent to renderer"]
    end

    subgraph Cloud["Gemini Cloud"]
        WS["WebSocket<br/>BidiGenerateContent"]
        Gemini["Gemini 2.5 Flash<br/>native-audio-preview"]
    end

    subgraph Tools["Tool Targets"]
        DT["Desktop Tools<br/>window.eve.desktop"]
        MCP["MCP Servers<br/>window.eve.mcp"]
        BT["Browser Tools<br/>window.eve.browser"]
        Claude["Claude API<br/>ask_claude"]
    end

    Mic --> AW
    AW --> NG
    NG --> B64
    B64 -->|"realtime_input<br/>audio/pcm;rate=16000"| Proxy
    SC -->|"realtime_input<br/>image/jpeg"| Proxy

    Proxy -->|"send()"| IPCout
    IPCout --> WSHandler
    IPCconn --> WSHandler
    WSHandler --> WS

    WS --> Gemini
    Gemini --> WS

    WS --> WSHandler
    WSHandler --> IPCin
    IPCin --> Proxy

    Proxy -->|"audioData"| APE
    Proxy -->|"text transcript"| SM
    Proxy -->|"toolCall"| TE

    TE --> DT
    TE --> MCP
    TE --> BT
    TE --> Claude

    DT -->|"result"| Proxy
    MCP -->|"result"| Proxy
    BT -->|"result"| Proxy
    Claude -->|"result"| Proxy

    SM -->|"on disconnect"| EM

    style Renderer fill:#1a1a2e,stroke:#e94560,color:#eee
    style IPC fill:#2a1a3e,stroke:#e94560,color:#eee
    style Main fill:#0f3460,stroke:#e94560,color:#eee
    style Cloud fill:#0f3460,stroke:#e94560,color:#eee
    style Tools fill:#16213e,stroke:#e94560,color:#eee
