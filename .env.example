# ─── Agent Friday — API Keys ──────────────────────────────────
# Copy this file to .env and fill in your keys.
# Keys can also be set in the app via Settings → API Keys.
# ──────────────────────────────────────────────────────────────

# REQUIRED — Gemini API key for voice conversation (Gemini Live)
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# RECOMMENDED — Anthropic API key for Claude Opus deep reasoning
# Sign up at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OPTIONAL — ElevenLabs API key for multi-agent distinct voices
# Sign up at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# OPTIONAL — OpenRouter API key for model routing (access multiple LLMs)
# Sign up at: https://openrouter.ai/
OPENROUTER_API_KEY=

# OPTIONAL — Firecrawl API key for web scraping & crawling
# Sign up at: https://firecrawl.dev/
FIRECRAWL_API_KEY=

# OPTIONAL — OpenAI API key (used for embeddings or specific model access)
# Sign up at: https://platform.openai.com/
OPENAI_API_KEY=

# OPTIONAL — Perplexity API key for web search-augmented responses
# Sign up at: https://docs.perplexity.ai/
PERPLEXITY_API_KEY=
